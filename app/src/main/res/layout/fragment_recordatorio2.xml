                            android:inputType="date" />

                        <CheckBox
                            android:id="@+id/checkBox6"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

